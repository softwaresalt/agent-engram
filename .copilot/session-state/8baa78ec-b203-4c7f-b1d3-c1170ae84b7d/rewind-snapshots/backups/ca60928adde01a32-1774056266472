)\r\n37. }\r\n38. \r\n39. /// Return the ready-wait timeout in milliseconds.\r\n40. ///\r\n41. /// Reads `ENGRAM_READY_TIMEOUT_MS` from the environment. Falls back to\r\n42. /// [`DEFAULT_READY_TIMEOUT_MS`] (10 s) if the variable is absent or cannot\r\n43. /// be parsed as a `u64`.\r\n44. fn ready_timeout_ms() -> u64 {\r\n45.     parse_timeout_ms(std::env::var(\"ENGRAM_READY_TIMEOUT_MS\").ok().as_deref())\r\n46. }\r\n47. \r\n48. // ── Health check ─────────────────────────────────────────────────────────────\r\n49. \r\n50. /// Check whether a daemon is healthy at `endpoint`.\r\n51. ///\r\n52. /// Sends an `_health` JSON-RPC request with a short timeout. Returns `true`\r\n53. /// if the response contains `\"status\": \"ready\"`, `false` on any error or\r\n54. /// unexpected payload.\r\n55. #[instrument(fields(endpoint = %endpoint))]\r\n56. pub async fn check_health(endpoint: &str) -> bool {\r\n57.     let request = IpcRequest {\r\n58.         jsonrpc: \"2.0\".to_owned(),\r\n59.         id: Some(Value::Number(serde_json::Number::from(0))),\r\n60.         method: \"_health\".to_owned(),\r\n61.         params: None,\r\n62.     };\r\n63. \r\n64.     match crate::shim::ipc_client::send_request(endpoint, &request, Duration::from_millis(500))\r\n65.         .await\r\n66.     {\r\n67.         Ok(response) => {\r\n68.             let is_ready = response\r\n69.                 .result\r\n70.                 .as_ref()\r\n71.                 .and_then(|v| v.get(\"status\"))\r\n72.                 .and_then(|s| s.as_str())\r\n73.                 == Some(\"ready\");\r\n74.             debug!(ready = is_ready, \"health check returned\");\r\n75.             is_ready\r\n76.         }\r\n77.         Err(e) => {\r\n78.             debug!(error = %e, \"health check failed\");\r\n79.             false\r\n80.         }\r\n81.     }\r\n82. }\r\n83. \r\n84. // ── Daemon lifecycle ──────────────────────────────────────────────────────────\r\n85. \r\n86. /// Ensure the daemon is running for `